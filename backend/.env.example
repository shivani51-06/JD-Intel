# Anthropic Claude API key — used for JD parsing, resume segmentation, and bullet rewrites
ANTHROPIC_API_KEY=

# Reddit API credentials (PRAW) — used by the Interview Scraper agent
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=jd-intel/0.1

# ChromaDB persistence path for cached interview signals
CHROMA_PERSIST_PATH=./chroma_data

# Frontend origin(s) allowed by CORS — comma-separated for multiple
FRONTEND_URL=http://localhost:3000,https://your-app.vercel.app
